# --- Form submission endpoints ---
# Option A (recommended): set each form independently
CHECKLIST_FORM_ENDPOINT=https://example.com/checklist-endpoint
AUDIT_FORM_ENDPOINT=https://example.com/audit-endpoint

# Option B (quick setup): one endpoint for both forms
# FORMS_ENDPOINT=https://example.com/forms-endpoint

# Optional: choose payload format sent to upstream endpoint
# Allowed values: json | form
# FORM_SUBMIT_CONTENT_TYPE=json

# Optional public fallback vars (only use if needed)
# NEXT_PUBLIC_CHECKLIST_FORM_ENDPOINT=
# NEXT_PUBLIC_AUDIT_FORM_ENDPOINT=
# NEXT_PUBLIC_FORMS_ENDPOINT=
